{
  "schema_version": "vc_demo_artifact_acquisition_sources.v1",
  "cell_line": "K562",
  "default_policy": {
    "formal_search": "never_fabricate_artifacts",
    "when_missing": "verify_existing_then_execute_known_resolver_then_generate_codex_research_task",
    "source_priority": [
      "official_or_primary_source",
      "published_author_dataset",
      "approved_public_repository"
    ],
    "forbidden": [
      "random_embeddings",
      "synthetic_graph_edges",
      "unversioned_downloads_marked_as_real"
    ]
  },
  "artifacts": [
    {
      "id": "esm2_gene_embedding_h5ad",
      "resolver": "download_from_known_huggingface_dataset",
      "expected_path": "data/artifacts/gene_embeddings/ESM2_D1280.h5ad",
      "source": "huggingface:genbio-ai/foundation-models-perturbation/gene_embeddings/ESM2_(D=1280).h5ad",
      "command": "python scripts/download_foundation_artifact.py --path gene_embeddings/ESM2_(D=1280).h5ad --output data/artifacts/gene_embeddings/ESM2_D1280.h5ad",
      "can_execute_automatically": true,
      "post_acquisition_audit": "python -m vc_demo.harness.artifact_registry --cell-line K562"
    },
    {
      "id": "esm2_k562_target_manifest",
      "resolver": "derive_from_known_esm2_embedding",
      "expected_path": "data/cell_lines/k562_concat_esm2_gene_embedding/artifact_manifest.json",
      "source": "derived_by:scripts/build_target_gene_artifact.py from ESM2_D1280.h5ad and K562 data split target genes",
      "command": "python scripts/build_target_gene_artifact.py --data-dir data/cell_lines/k562_concat_esm2_gene_embedding --embedding-h5ad data/artifacts/gene_embeddings/ESM2_D1280.h5ad --artifact-name ESM2_D1280 --gene-column symbol --summary experiments/k562_target_aware_artifact_manifest_summary.json",
      "can_execute_automatically": true,
      "post_acquisition_audit": "python -m vc_demo.harness.artifact_registry --cell-line K562"
    },
    {
      "id": "string_k562_gene_graph",
      "resolver": "build_from_official_string_api",
      "expected_path": "data/artifacts/string/k562_target_graph_edges.tsv",
      "source": "STRING official API v12 stable endpoint; K562 perturbation+target induced subgraph",
      "command": "python scripts/build_k562_string_graph.py --data-dir data/cell_lines/k562_concat_esm2_gene_embedding --output data/artifacts/string/k562_target_graph_edges.tsv --summary experiments/k562_string_graph_artifact_summary.json",
      "can_execute_automatically": true,
      "post_acquisition_audit": "python -m vc_demo.harness.artifact_registry --cell-line K562"
    },
    {
      "id": "pathway_memberships",
      "resolver": "build_from_official_reactome_gmt",
      "expected_path": "data/artifacts/pathways/k562_target_pathway_membership.npz",
      "source": "Reactome official GMT download https://reactome.org/download/current/ReactomePathways.gmt.zip aligned to exact official K562 target genes",
      "can_execute_automatically": true,
      "research_questions": [
        "Which public pathway source can be used without license ambiguity for this repo?",
        "What version/date/source URL is used?",
        "How are pathway identifiers and target gene symbols aligned?",
        "What is target gene coverage and pathway count?"
      ],
      "required_outputs": [
        "membership npz aligned to official 6,640 target genes",
        "summary json with Reactome source/version/coverage/filtering",
        "registry metadata update"
      ],
      "command": "python scripts/build_k562_pathway_membership.py --data-dir data/cell_lines/official_k562_cls --target-genes-tsv data/cell_lines/official_k562_cls/target_genes.tsv --output data/artifacts/pathways/k562_target_pathway_membership.npz --summary experiments/k562_pathway_membership_artifact_summary.json --registry configs/artifacts/k562_registry.json --update-registry",
      "post_acquisition_audit": "python -m vc_demo.harness.artifact_registry --cell-line K562",
      "aliases": [
        "pathway_membership_matrix"
      ]
    },
    {
      "id": "scfoundation_cell_embeddings",
      "resolver": "codex_research_download_or_encode_from_official_scfoundation_source",
      "expected_path": "data/artifacts/scfoundation",
      "source": "precomputed scFoundation cell-state embedding or approved encoder output; exact source must be documented before use",
      "can_execute_automatically": false,
      "research_questions": [
        "Is there an official/public scFoundation artifact matching these K562 perturbation rows?",
        "If not precomputed, what official checkpoint/code can encode the exact train/val/test cells?",
        "What input normalization and gene vocabulary are required?",
        "What file layout should the repo read at data/artifacts/scfoundation?"
      ],
      "required_outputs": [
        "embedding files or encoder output",
        "summary json with source/checkpoint/vocabulary/coverage",
        "registry update"
      ]
    },
    {
      "id": "aido_gene_or_cell_embeddings",
      "resolver": "codex_research_download_from_official_genbio_or_aido_source",
      "expected_path": "data/artifacts/aido",
      "source": "official/public AIDO artifact if available; exact file and source must be recorded",
      "can_execute_automatically": false,
      "research_questions": [
        "Which AIDO artifact family is required for the selected blueprint: gene, protein, cell, or multimodal?",
        "Is a public GenBio AI/HuggingFace artifact available?",
        "How is it aligned to perturbation genes, target genes, or cell rows?"
      ],
      "required_outputs": [
        "artifact files",
        "alignment summary",
        "registry update"
      ]
    },
    {
      "id": "pretrained_encoder",
      "resolver": "definition_required_before_acquisition",
      "expected_path": "data/artifacts/pretrained_encoder",
      "source": "must be specified by blueprint before use; can be local pretraining output or official checkpoint",
      "can_execute_automatically": false,
      "research_questions": [
        "Which encoder architecture/checkpoint is intended by selective_adapter_finetune?",
        "Is this a pretrained cell encoder, perturbation encoder, gene encoder, or previous root checkpoint?",
        "What tensor contract does the adapter expect?"
      ],
      "required_outputs": [
        "definition note",
        "checkpoint or rejected-blueprint decision",
        "registry update if real artifact is acquired"
      ]
    },
    {
      "id": "official_essential_deg_with_split_h5ad",
      "resolver": "download_from_known_huggingface_dataset",
      "expected_path": "data/artifacts/official_k562/essential_deg_with_split.h5ad",
      "source": "huggingface:genbio-ai/foundation-models-perturbation/essential/essential_deg_with_split.h5ad",
      "command": "python scripts/download_foundation_artifact.py --path essential/essential_deg_with_split.h5ad --output data/artifacts/official_k562/essential_deg_with_split.h5ad",
      "can_execute_automatically": true,
      "post_acquisition_audit": "python scripts/build_official_k562_task.py build && python scripts/build_official_k562_task.py validate"
    },
    {
      "id": "official_k562_aido_cell_100m_embedding_h5ad",
      "resolver": "download_from_known_huggingface_dataset",
      "expected_path": "data/artifacts/official_k562/AIDOcell_100M_essential_K562_D640.h5ad",
      "source": "huggingface:genbio-ai/foundation-models-perturbation/gene_embeddings/AIDOcell_100M_essential_K-562_2025_11_26_(D=640).h5ad",
      "command": "python scripts/download_foundation_artifact.py --path gene_embeddings/AIDOcell_100M_essential_K-562_2025_11_26_(D=640).h5ad --output data/artifacts/official_k562/AIDOcell_100M_essential_K562_D640.h5ad",
      "can_execute_automatically": true,
      "post_acquisition_audit": "python -m vc_demo.harness.artifact_registry --cell-line K562"
    },
    {
      "id": "official_string_gnn_keep20_graph",
      "resolver": "download_from_known_huggingface_dataset",
      "expected_path": "data/artifacts/official_k562/9606.protein.links.ensembl_900_keep20_adaptive.txt",
      "source": "huggingface:genbio-ai/foundation-models-perturbation/gnn/9606.protein.links.ensembl_900_keep20_adaptive.txt",
      "command": "python scripts/download_foundation_artifact.py --path gnn/9606.protein.links.ensembl_900_keep20_adaptive.txt --output data/artifacts/official_k562/9606.protein.links.ensembl_900_keep20_adaptive.txt",
      "can_execute_automatically": true,
      "post_acquisition_audit": "python -m vc_demo.harness.artifact_registry --cell-line K562"
    },
    {
      "id": "official_aido_cell_100m_model_dir",
      "resolver": "download_selected_files_from_public_huggingface_model",
      "expected_path": "/home/Models/AIDO.Cell-100M",
      "source": "Exact AutoModel directory expected by official VCHarness public node code.",
      "can_execute_automatically": true,
      "research_questions": [
        "Is /home/Models/AIDO.Cell-100M publicly downloadable as a HuggingFace model or GenBio release?",
        "What tokenizer/model revision matches the public VCHarness generated code?",
        "Can the downloaded h5ad embedding replace this checkpoint for an embedding-only baseline, and how should that limitation be recorded?"
      ],
      "required_outputs": [
        "model directory or explicit blocker report",
        "source URL/revision/checksum",
        "registry update"
      ],
      "command": "python scripts/download_hf_model_snapshot.py --repo-id genbio-ai/AIDO.Cell-100M --output-dir /home/Models/AIDO.Cell-100M --include config.json generation_config.json model.safetensors README.md LICENSE --manifest experiments/official_k562_task_contract/aido_cell_100m_model_dir_manifest.json",
      "post_acquisition_audit": "python scripts/validate_official_model_dirs.py --output experiments/official_k562_task_contract/model_dir_validation.json"
    },
    {
      "id": "official_string_gnn_model_dir",
      "resolver": "codex_research_download_from_official_genbio_or_string_gnn_source",
      "expected_path": "/home/Models/STRING_GNN",
      "source": "Hugging Face model repo genbio-ai/STRING_GNN exists, but API currently lists only .gitattributes; exact model weights remain unavailable.",
      "can_execute_automatically": false,
      "research_questions": [
        "Is /home/Models/STRING_GNN publicly downloadable, or must it be trained from gnn/9606...keep20 graph?",
        "What node embedding dimensionality and vocabulary are expected by VCHarness K562 best node?",
        "How should the repo distinguish STRING graph source data from trained STRING_GNN checkpoint?"
      ],
      "required_outputs": [
        "model directory or explicit blocker report",
        "source/build procedure",
        "registry update"
      ]
    },
    {
      "id": "official_gnn_simple_embedding_h5ad",
      "resolver": "download_from_known_huggingface_dataset",
      "expected_path": "data/artifacts/official_k562/GNN_Simple_Official_D256.h5ad",
      "source": "huggingface:genbio-ai/foundation-models-perturbation/gene_embeddings/GNN_Simple_Official_(D=256).h5ad",
      "command": "python scripts/download_foundation_artifact.py --path gene_embeddings/GNN_Simple_Official_(D=256).h5ad --output data/artifacts/official_k562/GNN_Simple_Official_D256.h5ad",
      "can_execute_automatically": true,
      "post_acquisition_audit": "python -m vc_demo.harness.artifact_registry --cell-line K562"
    }
  ]
}
