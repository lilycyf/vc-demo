{
  "id": "official_k562_paper_scale_search_space",
  "scope": "demo_projection_K562_CRISPR_DEG",
  "paper_scale_contract": {
    "minimum_budget_nodes_for_paper_scale_single_cellline": 600,
    "public_static_scaffold_nodes": 154,
    "recommended_medium_budget_nodes": 150,
    "recommended_full_budget_nodes": 600,
    "node_definition": "one complete candidate training pipeline with full artifact-backed implementation, not a small hyperparameter tweak and not a compact/proxy stand-in",
    "planned_blueprints_are_selectable": true,
    "codex_implements_on_selection": true,
    "strict_artifacts_default": true,
    "fallback_allowed_in_official_mode": false,
    "compact_native_or_proxy_allowed_in_official_mode": false,
    "search_space_is_manifest_not_preimplementation": true,
    "codex_agent_materializes_planned_nodes_on_selection": true,
    "minimum_estimated_candidate_families": 600,
    "paper_scale_run_label_required_for_budget_ge": 600
  },
  "mcts_contract": {
    "selection_policy": "uct_or_puct",
    "required_record_fields": [
      "selected_parent",
      "candidate_list",
      "visits",
      "Q",
      "exploration_term",
      "reward",
      "backprop_path"
    ],
    "scale_requirement": "A paper-scale K562 run should be configured for 600+ budget nodes unless explicitly labeled pilot/smoke."
  },
  "blueprint_families": [
    {
      "family": "public_static_tree",
      "role": "benchmark scaffold and optional external wrappers",
      "count_target": 154
    },
    {
      "family": "AIDO",
      "role": "embedding, adapter, LoRA, selective and full fine-tuning"
    },
    {
      "family": "scFoundation_or_single_cell_foundation",
      "role": "cell/expression encoder when real artifacts are present"
    },
    {
      "family": "STRING_GNN",
      "role": "graph embedding, frozen cache, fine-tune, K-hop attention, smoothing"
    },
    {
      "family": "AIDO_STRING_fusion",
      "role": "concat, gated, bilinear, cross-attention, MoE"
    },
    {
      "family": "target_gene_heads",
      "role": "low-rank, bilinear, graph-conditioned, calibrated heads"
    },
    {
      "family": "pathway_and_regulatory_priors",
      "role": "Reactome/pathway pooling and regulatory networks when acquired"
    },
    {
      "family": "training_strategy",
      "role": "weighted CE, focal loss, layerwise LR, SWA/checkpoint ensemble"
    },
    {
      "family": "ESM2_size_sweep",
      "role": "protein language model branches at 35M/150M/650M/3B scale"
    },
    {
      "family": "gene_text_and_functional_priors",
      "role": "GenePT GO/NCBI/UniProt, DepMap, and genotype priors"
    },
    {
      "family": "single_cell_foundation_expanded",
      "role": "Geneformer, TranscriptFormer, scPRINT, scGPT, scFoundation, AIDO.Cell size sweep"
    },
    {
      "family": "STRING_variant_family",
      "role": "STRING Spectral, Seq, WaveGC, Net, GNN Simple, and original STRING_GNN"
    },
    {
      "family": "sequence_and_regulatory_task_gated",
      "role": "AIDO.DNA/DNA2 and AlphaGenome when a sequence/regulatory task is requested"
    },
    {
      "family": "scratch_and_ablation_controls",
      "role": "no-pretrained and ablation controls so gains are interpretable"
    }
  ],
  "codex_on_demand_rules": {
    "when_selected": [
      "write IMPLEMENTATION_REQUEST.md",
      "implement full artifact-backed node-local model.py or config-only training patch",
      "run native smoke",
      "train/evaluate",
      "record metrics or blocker"
    ],
    "allowed_changes": [
      "node-local model.py",
      "node-local pipeline metadata",
      "approved helper under src/vc_demo/official_k562"
    ],
    "forbidden_changes": [
      "official splits",
      "labels",
      "target gene order",
      "metric semantics",
      "artifact provenance",
      "silent fallback",
      "compact/proxy/simplified stand-ins"
    ]
  },
  "status_taxonomy": {
    "implemented": "already executable by harness",
    "planned": "selectable; Codex must implement on demand before training",
    "blocked_missing_artifact": "must acquire artifact or stop; no fallback training",
    "blocked_proxy_implementation": "must replace with exact public static execution or full artifact-backed implementation before training"
  },
  "blueprint_entry_required_fields": [
    "id",
    "family",
    "status",
    "required_artifacts",
    "input_contract",
    "output_contract",
    "codex_action",
    "allowed_changes",
    "forbidden_changes",
    "smoke_command",
    "cost_class",
    "paper_alignment_claim"
  ],
  "scale_tiers": [
    {
      "id": "smoke",
      "budget_nodes": "3-5",
      "purpose": "wiring only"
    },
    {
      "id": "pilot",
      "budget_nodes": "20-50",
      "purpose": "repair/acquisition/MCTS pressure test"
    },
    {
      "id": "medium",
      "budget_nodes": 150,
      "purpose": "breadth and reporting attribution"
    },
    {
      "id": "paper_scale_single_cellline",
      "budget_nodes": "600+",
      "purpose": "K562 paper-order search scale"
    }
  ],
  "search_dimensions": [
    {
      "dimension": "backbone",
      "options": [
        "AIDO.Cell-100M",
        "AIDO cached embedding",
        "single-cell foundation encoder",
        "STRING_GNN",
        "public static wrapper",
        "native public-best reimplementation",
        "AIDO.DNA",
        "AIDO.DNA2",
        "AIDO.Cell 3M",
        "AIDO.Cell 10M",
        "AIDO.Cell 100M",
        "AIDO.Protein",
        "AIDO Protein 16B",
        "ProteinRAG 16B + structure",
        "scGPT",
        "scFoundation",
        "Geneformer",
        "TranscriptFormer",
        "scPRINT",
        "No pretrained / scratch baseline"
      ]
    },
    {
      "dimension": "adapter",
      "options": [
        "LoRA",
        "frozen adapter",
        "selective layer tuning",
        "full fine-tune",
        "cached embedding projection"
      ]
    },
    {
      "dimension": "graph_prior",
      "options": [
        "STRING frozen embedding",
        "K-hop attention",
        "message passing",
        "Laplacian smoothing",
        "graph-conditioned head",
        "STRING Spectral",
        "STRING Seq",
        "STRING WaveGC",
        "STRING Net",
        "GNN Simple Official D256"
      ]
    },
    {
      "dimension": "fusion",
      "options": [
        "concat",
        "gated",
        "bilinear",
        "cross-attention",
        "mixture-of-experts",
        "late fusion",
        "residual fusion"
      ]
    },
    {
      "dimension": "target_head",
      "options": [
        "shared head",
        "target-specific head",
        "low-rank head",
        "bilinear head",
        "calibrated head"
      ]
    },
    {
      "dimension": "training_strategy",
      "options": [
        "weighted CE",
        "focal loss",
        "class-balanced loss",
        "layerwise LR",
        "SWA",
        "checkpoint ensemble"
      ]
    },
    {
      "dimension": "biological_prior",
      "options": [
        "pathway membership",
        "Reactome pooling",
        "regulatory network prior"
      ]
    },
    {
      "dimension": "protein_language_model",
      "options": [
        "ESM2 35M",
        "ESM2 150M",
        "ESM2 650M",
        "ESM2 3B"
      ]
    },
    {
      "dimension": "gene_text_and_functional_prior",
      "options": [
        "GenePT All",
        "GenePT BP",
        "GenePT CC",
        "GenePT MF",
        "GenePT NCBI",
        "GenePT N+U",
        "DepMap",
        "GenotypeVAE"
      ]
    },
    {
      "dimension": "positional_or_sequence_prior",
      "options": [
        "Positional 3M",
        "Positional 10M",
        "Positional 100M",
        "AlphaGenome"
      ]
    }
  ],
  "candidate_expansion_contract": {
    "method": "manifest_cross_product_with_blueprint_constraints",
    "estimated_candidate_formula": "sum of valid backbone x adapter x graph_prior x fusion x target_head x training_strategy x prior combinations after artifact/status constraints",
    "do_not_preimplement_all_candidates": true,
    "planned_candidate_execution": "MCTS may select a planned blueprint; Codex implements that node only after selection.",
    "paper_universe_manifest_required": true,
    "minimum_universe_modules_required": 40,
    "task_gating_is_not_omission": true
  },
  "artifact_policies": [
    {
      "artifact_family": "AIDO",
      "policy": "present_or_acquire_public_source",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "STRING_GNN",
      "policy": "present_or_mark_reconstructed_compatibility",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "scFoundation_or_single_cell_foundation",
      "policy": "acquire_if_source_is_public_else_block",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "AIDO_embedding",
      "policy": "public_or_derived_with_checksum",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "GNN_embedding",
      "policy": "public_or_derived_with_checksum",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "pathway_membership",
      "policy": "build_from_public_pathway_database_when_possible",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "regulatory_network",
      "policy": "acquire_public_source_else_block",
      "fallback": "forbidden_in_strict_mode"
    }
  ],
  "scientific_search_policy": {
    "artifact_present_is_not_search_signal": true,
    "selection_order": [
      "scientific_prior",
      "family_coverage",
      "structural_novelty",
      "repeat_penalty",
      "feasibility_gate"
    ],
    "feasibility_gate_after_selection": true,
    "strict_missing_artifact_behavior": "acquire_or_block_no_fallback",
    "replicate_nodes_do_not_count_as_discovery": true,
    "default_min_family_coverage_before_no_improve_stop": 5,
    "early_coverage_families": [
      "official_aido_string_fusion",
      "official_string_gnn_attention",
      "official_aido_lora_adapter",
      "official_target_gene_head",
      "official_class_imbalance_training",
      "official_pathway_pooling_reactome",
      "official_public_best_node"
    ]
  },
  "paper_model_universe_manifest": "configs/vcharness_paper_model_universe.json",
  "coverage_requirement": {
    "rule": "This K562 file is only a task-gated demo projection of configs/vcharness_paper_model_universe.json. It may add K562-specific combinations for testing, but it must not redefine the global universe or make K562-specific choices universal.",
    "audit_command": "python scripts/audit_paper_model_universe.py",
    "cannot_be_smaller_than_paper": true,
    "paper_original_modules_must_be_listed_even_when_blocked_or_task_gated": true
  },
  "paper_universe_task_gates": {
    "selection_rule": "Task-gated modules stay in the universe and count toward paper coverage. K562 uses this list only as a demo projection; a different cell line or task must recompute artifact registry, roots, and gates from its own task contract.",
    "CRISPR_DEG_candidate_modules_for_K562_demo": [
      "AIDO.Cell-3M",
      "AIDO.Cell-10M",
      "AIDO.Cell-100M",
      "AIDO cached embedding",
      "scFoundation",
      "scGPT",
      "Geneformer",
      "TranscriptFormer",
      "scPRINT",
      "STRING_GNN",
      "STRING graph/PPI",
      "STRING Spectral",
      "STRING Seq",
      "STRING WaveGC",
      "STRING Net",
      "GNN Simple Official D256",
      "ESM2 35M",
      "ESM2 150M",
      "ESM2 650M",
      "ESM2 3B",
      "GenePT All",
      "GenePT BP",
      "GenePT CC",
      "GenePT MF",
      "GenePT NCBI",
      "GenePT N+U",
      "DepMap",
      "Reactome/pathway memberships",
      "regulatory network priors",
      "scratch baseline",
      "public VCHarness static tree nodes"
    ],
    "task_gated_not_default_for_CRISPR_DEG_demo": [
      "AIDO.DNA",
      "AIDO.DNA2",
      "AlphaGenome",
      "GenotypeVAE unless genotype covariates are available",
      "Positional 3M/10M/100M unless genomic coordinate features are acquired",
      "AIDO.Protein-16B/ProteinRAG-16B unless protein branch compute/storage is approved"
    ]
  },
  "cell_line_overfit_guard": {
    "role": "K562 is a validation/demo cell line for the generic harness, not the universal template.",
    "do_not_generalize": [
      "K562 best child motifs",
      "K562 artifact availability",
      "K562 target-gene order",
      "K562 root dominance behavior",
      "K562-specific public static wrapper paths"
    ],
    "must_generalize": [
      "paper model universe coverage",
      "task-gated projection mechanism",
      "source-backed artifact acquisition/block semantics",
      "MCTS proposal-pool selection and trained-only backprop",
      "no fallback/proxy guardrails"
    ]
  }
}
