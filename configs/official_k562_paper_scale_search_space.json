{
  "id": "official_k562_paper_scale_search_space",
  "scope": "single_cell_line_K562",
  "paper_scale_contract": {
    "minimum_budget_nodes_for_paper_scale_single_cellline": 600,
    "public_static_scaffold_nodes": 154,
    "recommended_medium_budget_nodes": 150,
    "recommended_full_budget_nodes": 600,
    "node_definition": "one complete candidate training pipeline with full artifact-backed implementation, not a small hyperparameter tweak and not a compact/proxy stand-in",
    "planned_blueprints_are_selectable": true,
    "codex_implements_on_selection": true,
    "strict_artifacts_default": true,
    "fallback_allowed_in_official_mode": false,
    "compact_native_or_proxy_allowed_in_official_mode": false,
    "search_space_is_manifest_not_preimplementation": true,
    "codex_agent_materializes_planned_nodes_on_selection": true,
    "minimum_estimated_candidate_families": 600,
    "paper_scale_run_label_required_for_budget_ge": 600
  },
  "mcts_contract": {
    "selection_policy": "uct_or_puct",
    "required_record_fields": [
      "selected_parent",
      "candidate_list",
      "visits",
      "Q",
      "exploration_term",
      "reward",
      "backprop_path"
    ],
    "scale_requirement": "A paper-scale K562 run should be configured for 600+ budget nodes unless explicitly labeled pilot/smoke."
  },
  "blueprint_families": [
    {
      "family": "public_static_tree",
      "role": "benchmark scaffold and optional external wrappers",
      "count_target": 154
    },
    {
      "family": "AIDO",
      "role": "embedding, adapter, LoRA, selective and full fine-tuning"
    },
    {
      "family": "scFoundation_or_single_cell_foundation",
      "role": "cell/expression encoder when real artifacts are present"
    },
    {
      "family": "STRING_GNN",
      "role": "graph embedding, frozen cache, fine-tune, K-hop attention, smoothing"
    },
    {
      "family": "AIDO_STRING_fusion",
      "role": "concat, gated, bilinear, cross-attention, MoE"
    },
    {
      "family": "target_gene_heads",
      "role": "low-rank, bilinear, graph-conditioned, calibrated heads"
    },
    {
      "family": "pathway_and_regulatory_priors",
      "role": "Reactome/pathway pooling and regulatory networks when acquired"
    },
    {
      "family": "training_strategy",
      "role": "weighted CE, focal loss, layerwise LR, SWA/checkpoint ensemble"
    }
  ],
  "codex_on_demand_rules": {
    "when_selected": [
      "write IMPLEMENTATION_REQUEST.md",
      "implement full artifact-backed node-local model.py or config-only training patch",
      "run native smoke",
      "train/evaluate",
      "record metrics or blocker"
    ],
    "allowed_changes": [
      "node-local model.py",
      "node-local pipeline metadata",
      "approved helper under src/vc_demo/official_k562"
    ],
    "forbidden_changes": [
      "official splits",
      "labels",
      "target gene order",
      "metric semantics",
      "artifact provenance",
      "silent fallback",
      "compact/proxy/simplified stand-ins"
    ]
  },
  "status_taxonomy": {
    "implemented": "already executable by harness",
    "planned": "selectable; Codex must implement on demand before training",
    "blocked_missing_artifact": "must acquire artifact or stop; no fallback training",
    "blocked_proxy_implementation": "must replace with exact public static execution or full artifact-backed implementation before training"
  },
  "blueprint_entry_required_fields": [
    "id",
    "family",
    "status",
    "required_artifacts",
    "input_contract",
    "output_contract",
    "codex_action",
    "allowed_changes",
    "forbidden_changes",
    "smoke_command",
    "cost_class",
    "paper_alignment_claim"
  ],
  "scale_tiers": [
    {
      "id": "smoke",
      "budget_nodes": "3-5",
      "purpose": "wiring only"
    },
    {
      "id": "pilot",
      "budget_nodes": "20-50",
      "purpose": "repair/acquisition/MCTS pressure test"
    },
    {
      "id": "medium",
      "budget_nodes": 150,
      "purpose": "breadth and reporting attribution"
    },
    {
      "id": "paper_scale_single_cellline",
      "budget_nodes": "600+",
      "purpose": "K562 paper-order search scale"
    }
  ],
  "search_dimensions": [
    {
      "dimension": "backbone",
      "options": [
        "AIDO.Cell-100M",
        "AIDO cached embedding",
        "single-cell foundation encoder",
        "STRING_GNN",
        "public static wrapper",
        "native public-best reimplementation"
      ]
    },
    {
      "dimension": "adapter",
      "options": [
        "LoRA",
        "frozen adapter",
        "selective layer tuning",
        "full fine-tune",
        "cached embedding projection"
      ]
    },
    {
      "dimension": "graph_prior",
      "options": [
        "STRING frozen embedding",
        "K-hop attention",
        "message passing",
        "Laplacian smoothing",
        "graph-conditioned head"
      ]
    },
    {
      "dimension": "fusion",
      "options": [
        "concat",
        "gated",
        "bilinear",
        "cross-attention",
        "mixture-of-experts",
        "late fusion",
        "residual fusion"
      ]
    },
    {
      "dimension": "target_head",
      "options": [
        "shared head",
        "target-specific head",
        "low-rank head",
        "bilinear head",
        "calibrated head"
      ]
    },
    {
      "dimension": "training_strategy",
      "options": [
        "weighted CE",
        "focal loss",
        "class-balanced loss",
        "layerwise LR",
        "SWA",
        "checkpoint ensemble"
      ]
    },
    {
      "dimension": "biological_prior",
      "options": [
        "pathway membership",
        "Reactome pooling",
        "regulatory network prior"
      ]
    }
  ],
  "candidate_expansion_contract": {
    "method": "manifest_cross_product_with_blueprint_constraints",
    "estimated_candidate_formula": "sum of valid backbone x adapter x graph_prior x fusion x target_head x training_strategy x prior combinations after artifact/status constraints",
    "do_not_preimplement_all_candidates": true,
    "planned_candidate_execution": "MCTS may select a planned blueprint; Codex implements that node only after selection."
  },
  "artifact_policies": [
    {
      "artifact_family": "AIDO",
      "policy": "present_or_acquire_public_source",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "STRING_GNN",
      "policy": "present_or_mark_reconstructed_compatibility",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "scFoundation_or_single_cell_foundation",
      "policy": "acquire_if_source_is_public_else_block",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "AIDO_embedding",
      "policy": "public_or_derived_with_checksum",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "GNN_embedding",
      "policy": "public_or_derived_with_checksum",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "pathway_membership",
      "policy": "build_from_public_pathway_database_when_possible",
      "fallback": "forbidden_in_strict_mode"
    },
    {
      "artifact_family": "regulatory_network",
      "policy": "acquire_public_source_else_block",
      "fallback": "forbidden_in_strict_mode"
    }
  ],
  "scientific_search_policy": {
    "artifact_present_is_not_search_signal": true,
    "selection_order": [
      "scientific_prior",
      "family_coverage",
      "structural_novelty",
      "repeat_penalty",
      "feasibility_gate"
    ],
    "feasibility_gate_after_selection": true,
    "strict_missing_artifact_behavior": "acquire_or_block_no_fallback",
    "replicate_nodes_do_not_count_as_discovery": true,
    "default_min_family_coverage_before_no_improve_stop": 5,
    "early_coverage_families": [
      "official_aido_string_fusion",
      "official_string_gnn_attention",
      "official_aido_lora_adapter",
      "official_target_gene_head",
      "official_class_imbalance_training",
      "official_pathway_pooling_reactome",
      "official_public_best_node"
    ]
  }
}
